# ether-ocr — Environment Configuration
# Copy this file to .env and adjust values:
#   cp .env.example .env

# ─── Authentication ────────────────────────────────────────────
# Set to 0 to disable auth (development only)
AUTH_ENABLED=1

# Comma-separated list of valid API keys (stored as SHA-256 hashes in memory)
API_KEYS=dev-key-ether-ocr

# Secret for JWT verification (leave empty to disable JWT)
JWT_SECRET=

# ─── Server ────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# Comma-separated allowed CORS origins (* for all — NOT recommended for production)
CORS_ORIGINS=http://localhost:8000

# Maximum upload size in bytes (default: 50 MB)
MAX_UPLOAD_BYTES=52428800

# ─── Rate Limiting ─────────────────────────────────────────────
# Set to 0 to disable rate limiting
RATE_LIMIT_ENABLED=1

# Maximum requests per IP within the window
RATE_LIMIT_REQUESTS=30

# Rate limit window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ─── OCR ───────────────────────────────────────────────────────
OCR_DEFAULT_LANG=spa+eng
OCR_DEFAULT_DPI=300

# Maximum inline text size before returning tar.gz (bytes, default: 100 KB)
OCR_MAX_INLINE_BYTES=102400
