# ether-ocr — Environment Configuration
# Copy this file to .env and adjust values:
#   cp .env.example .env

# ─── Authentication ────────────────────────────────────────────
# Set to 0 to disable auth (development only)
AUTH_ENABLED=1

# Comma-separated list of valid API keys
API_KEYS=dev-key-ether-ocr

# Secret for JWT verification (leave empty to disable JWT)
JWT_SECRET=

# ─── Server ────────────────────────────────────────────────────
# Port for the API server
PORT=8000

# Host to bind (0.0.0.0 for Docker, 127.0.0.1 for local)
HOST=0.0.0.0

# Allowed CORS origins (comma-separated, * for all)
CORS_ORIGINS=*

# ─── OCR ───────────────────────────────────────────────────────
# Default language(s) for Tesseract OCR
OCR_DEFAULT_LANG=spa+eng

# Default DPI for PDF-to-image conversion
OCR_DEFAULT_DPI=300

# Maximum inline text size before returning tar.gz (bytes)
OCR_MAX_INLINE_BYTES=102400
